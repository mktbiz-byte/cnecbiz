# CNEC Discovery — 환경변수 템플릿
# .env로 복사 후 값을 채워주세요.

# ===== 서버 식별 =====
SERVER_REGION=kr                    # kr | jp | us
SERVER_NAME=cnec-disc-kr            # cnec-disc-kr | cnec-disc-jp | cnec-disc-us

# ===== Supabase (BIZ DB) =====
SUPABASE_BIZ_URL=
SUPABASE_BIZ_SERVICE_KEY=

# ===== Supabase (리전 DB) =====
SUPABASE_REGION_URL=
SUPABASE_REGION_SERVICE_KEY=

# ===== Influencers Club API =====
IC_API_KEY=

# ===== Apify =====
APIFY_API_TOKEN=

# ===== Google Gemini =====
GEMINI_API_KEY=

# ===== ZeroBounce =====
ZEROBOUNCE_API_KEY=

# ===== AWS SES =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ===== Instagram Graph API (DM) =====
INSTAGRAM_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=

# ===== 알림 =====
NAVER_WORKS_WEBHOOK_URL=
CNECBIZ_URL=https://cnecbiz.com
